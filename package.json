{
	"name": "revati_website",
	"version": "4.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm run licenses && vite build",
		"preview": "vite preview",
		"licenses": "tsx assets/scripts/collect-licenses.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"article": "tsx assets/scripts/create-article.ts"
	},
	"packageManager": "pnpm@10.25.0",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.25.0",
			"onFail": "error"
		}
	},
	"devDependencies": {
		"@quantco/pnpm-licenses": "2.2.4-0",
		"@typescript-eslint/eslint-plugin": "^7.6.0",
		"@typescript-eslint/parser": "^7.6.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.45.1",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte-check": "^4.0.0",
		"svelte-preprocess": "^6.0.3"
	},
	"type": "module",
	"dependencies": {
		"@sveltejs/adapter-cloudflare": "^3.0.0",
		"@sveltejs/kit": "^2.53.3",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/node": "^22.7.4",
		"@types/nprogress": "^0.2.3",
		"mdsvex": "^0.12.7",
		"nprogress": "^0.2.0",
		"sass": "^1.57.1",
		"svelte": "^5.0.0",
		"svelte-i18n": "^4.0.0",
		"tslib": "^2.4.1",
		"tsx": "^4.19.1",
		"typescript": "^5.5.0",
		"uuid": "^11.1.0",
		"vite": "^5.4.19"
	}
}
